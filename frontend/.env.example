# ===========================================
# MindLog Frontend 환경변수
# ===========================================
# 이 파일을 복사해서 .env.local 파일을 만드세요
# cp .env.example .env.local

# 백엔드 API URL
NEXT_PUBLIC_API_URL=http://localhost:8080/v1

# Mock 모드 (true: mock 사용, false: 실제 API 사용)
NEXT_PUBLIC_USE_MOCK=true

# ===========================================
# OAuth 설정 (소셜 로그인 사용 시 필수)
# ===========================================

# Kakao OAuth
# 카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키 > REST API 키
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key
# 카카오 개발자 콘솔에 등록된 Redirect URI (프론트엔드 URL)
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback

# Google OAuth
# Google Cloud Console > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
# Google Cloud Console에 등록된 Redirect URI (프론트엔드 URL)
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
